# Copy to .env.local. NEVER commit real keys. Only app/api/* (server) reads these.

# ---- master switch -------------------------------------------------------
# true  = use deterministic mocks for ALL services (build + demo on this)
# false = call real AWS. Flip per-service only once each is verified working.
USE_MOCKS=true

# ---- AWS (only needed when USE_MOCKS=false) ------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock model id (use a small/cheap model for dialogue; covered by $200 new-account credit)
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# Amazon Polly default voice (neural). e.g. Joanna / Matthew / Amy
POLLY_VOICE_ID=Joanna

# S3 bucket for recordings + report json (optional; download-only works without it)
S3_BUCKET=

# ---- notes ---------------------------------------------------------------
# - Set an AWS Budgets alert at $1 before flipping USE_MOCKS=false.
# - Transcribe free tier = 60 min/mo; prefer on-device Web Speech in the browser for STT.
# - Rekognition/Comprehend are optional Tier-3; keep mocked unless Tier 1-2 is demo-stable.
